{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../Src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "memberLayout": "separatePages"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml"
        ]
      },
      {
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "exclude": [
          "obj/**",
          "_site/**",
          "api/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "assets/**"
        ],
        "src": ".."
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/dokfx"
    ],
    "sitemap": {
      "baseUrl": "https://krykomdev.github.io/Metriks",
      "priority": 0.5,
      "changefreq": "monthly"
    },
    "globalMetadata": {
      "_appName": "Metriks",
      "_appTitle": "Metriks Documentation",
      "_gitRepo": "https://github.com/KryKomDev/NeoKolors",
      "_appTitle": "NeoKolors Documentation",
      "_appLogoPath": "assets/package-icon.png",
      "_appFaviconPath": "assets/package-icon.png",
      "_enableSearch": true,
      "_appFooter": "<span>Copyright &copy; 2026 KryKom and <a href='https://github.com/KryKomDev/Metriks/graphs/contributors?all=1'>Contributors</a> · Licensed under the MIT License · Source code on <a href='https://github.com/KryKomDev/Metriks' target='_blank'>GitHub</a> · Generated by <a href='https://dotnet.github.io/docfx/' target='_blank'>DocFX</a> using the <a href='https://github.com/KryKomDev/Dokfx' target='_blank'>Dokfx template</a></span>"
    }
  }
}